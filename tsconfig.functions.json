{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "./netlify/functions",
    "outDir": ".netlify/build/functions"
  },
  "include": ["netlify/functions"]
}
